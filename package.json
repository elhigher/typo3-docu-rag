{
  "name": "typo3-docu-rag",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "typo3-docu-rag": "dist/index.js"
  },
  "files": [
    "dist",
    "data/processed"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "fetch": "node --loader ts-node/esm src/scripts/fetch-docs.ts",
    "render": "node --loader ts-node/esm src/scripts/render-docs.ts",
    "parse": "node --loader ts-node/esm src/scripts/parse-docs.ts",
    "index": "node --loader ts-node/esm src/scripts/index-docs.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.11.0",
    "@types/turndown": "^5.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "glob": "^13.0.6",
    "jsdom": "^29.0.2",
    "simple-git": "^3.22.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
